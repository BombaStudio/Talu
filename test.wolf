let px : float = 400.0
let py : float = 300.0
let speed : float = 100.0
fn start()
    
end


fn update()
    drawCircle(px, py, 20.0, 131.0, 47.0, 47.0)
    if is_key_down("W")
        py = py - speed * deltaTime
    end
    if is_key_down("S")
        py = py + speed * deltaTime
    end
    if is_key_down("A")
        px = px - speed * deltaTime
    end
    if is_key_down("D")
        px = px + speed * deltaTime
    end
end